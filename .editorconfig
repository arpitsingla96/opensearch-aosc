root = true

[*]
charset = utf-8
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true
indent_style = space

[*.java]
indent_size = 4

[*.gradle]
indent_size = 2

[*.{json,yml,yaml}]
indent_size = 2

[*.xml]
indent_size = 4

[*.{sh,py}]
indent_size = 2

[*.md]
# Trailing whitespace in Markdown can be significant (line breaks)
trim_trailing_whitespace = false

[*.bat]
end_of_line = crlf

[Makefile]
indent_style = tab
