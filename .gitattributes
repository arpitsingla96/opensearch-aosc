# Auto-detect text files and normalize line endings
* text=auto

# Java sources
*.java text diff=java

# Gradle
*.gradle text diff
gradle.properties text
settings.gradle text

# Build scripts
*.sh text eol=lf
*.bat text eol=crlf
gradlew text eol=lf
gradlew.bat text eol=crlf

# Documentation
*.md text diff=markdown
*.txt text

# Data formats
*.json text
*.yml text
*.yaml text
*.xml text
*.svg text

# Properties
*.properties text

# Security policy
*.policy text

# Binary files — do not diff or normalize
*.jar binary
*.zip binary
*.gz binary
*.tar binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
