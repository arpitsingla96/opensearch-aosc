<?xml version="1.0" encoding="UTF-8"?><mxfile host="app.diagrams.net" type="device"><diagram id="aosc-routing" name="Power-of-two split fan-out"><mxGraphModel dx="1130" dy="640" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1150" pageHeight="560" math="0" shadow="0" background="#FFFFFF"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="sub" value="Example: splitting S = 3 shards into T = 12 (split factor k = T/S = 4)" style="text;html=1;align=center;fontStyle=2;fontColor=#5E6C84;fontFamily=Helvetica;fontSize=12;fontSize=12;" vertex="1" parent="1"><mxGeometry x="70" y="10" width="960" height="20" as="geometry"/></mxCell><mxCell id="hdr" value="shard = floorMod( murmur3(routing), R ) / f &#160;&#160; f = R / number_of_shards&lt;br&gt;R = number_of_routing_shards — fixed once, unchanged by a split" style="rounded=1;arcSize=6;absoluteArcSize=1;html=1;whiteSpace=wrap;align=center;fontColor=#42526E;fontFamily=Courier New;fontSize=13;fillColor=#F4F5F7;strokeColor=#C1C7D0;" vertex="1" parent="1"><mxGeometry x="160" y="40" width="780" height="50" as="geometry"/></mxCell><mxCell id="srclbl" value="Source index · 3 shards &#160;(f = R / 3)" style="text;html=1;align=left;fontStyle=1;fontColor=#5E6C84;fontFamily=Helvetica;fontSize=12;fontSize=12;" vertex="1" parent="1"><mxGeometry x="70" y="108" width="460" height="18" as="geometry"/></mxCell><mxCell id="s0" value="shard 0" style="rounded=1;arcSize=8;absoluteArcSize=1;html=1;whiteSpace=wrap;fontColor=#172B4D;fontFamily=Helvetica;fontSize=12;fillColor=#DEEBFF;strokeColor=#C1C7D0;" vertex="1" parent="1"><mxGeometry x="70" y="132" width="320" height="58" as="geometry"/></mxCell><mxCell id="s1" value="shard 1" style="rounded=1;arcSize=8;absoluteArcSize=1;html=1;whiteSpace=wrap;fontStyle=1;fontColor=#974F0C;fontFamily=Helvetica;fontSize=12;fillColor=#FFE9A8;strokeColor=#FF991F;strokeWidth=1.6;" vertex="1" parent="1"><mxGeometry x="390" y="132" width="320" height="58" as="geometry"/></mxCell><mxCell id="s2" value="shard 2" style="rounded=1;arcSize=8;absoluteArcSize=1;html=1;whiteSpace=wrap;fontColor=#172B4D;fontFamily=Helvetica;fontSize=12;fillColor=#DEEBFF;strokeColor=#C1C7D0;" vertex="1" parent="1"><mxGeometry x="710" y="132" width="320" height="58" as="geometry"/></mxCell><mxCell id="why" value="Same hash bucket, smaller routing factor:&lt;br&gt;shards &#215; k &#8658; f &#247; k, so each source shard&lt;br&gt;subdivides into k = 4 adjacent target shards.&lt;br&gt;&lt;br&gt;Only k must be a power of two — the shard&lt;br&gt;counts (here 3 &#8594; 12) need not be." style="text;html=1;align=left;verticalAlign=top;fontColor=#42526E;fontFamily=Helvetica;fontSize=12;fontSize=12;" vertex="1" parent="1"><mxGeometry x="80" y="198" width="290" height="118" as="geometry"/></mxCell><mxCell id="tgtlbl" value="Target index · 12 shards &#160;(f = R / 12)" style="text;html=1;align=left;fontStyle=1;fontColor=#5E6C84;fontFamily=Helvetica;fontSize=12;fontSize=12;" vertex="1" parent="1"><mxGeometry x="70" y="308" width="460" height="18" as="geometry"/></mxCell><mxCell id="t0" value="shard 0" style="rounded=1;arcSize=8;absoluteArcSize=1;html=1;whiteSpace=wrap;fontColor=#172B4D;fontFamily=Helvetica;fontSize=12;fillColor=#DEEBFF;strokeColor=#C1C7D0;" vertex="1" parent="1"><mxGeometry x="70" y="332" width="80" height="58" as="geometry"/></mxCell><mxCell id="t1" value="shard 1" style="rounded=1;arcSize=8;absoluteArcSize=1;html=1;whiteSpace=wrap;fontColor=#172B4D;fontFamily=Helvetica;fontSize=12;fillColor=#DEEBFF;strokeColor=#C1C7D0;" vertex="1" parent="1"><mxGeometry x="150" y="332" width="80" height="58" as="geometry"/></mxCell><mxCell id="t2" value="shard 2" style="rounded=1;arcSize=8;absoluteArcSize=1;html=1;whiteSpace=wrap;fontColor=#172B4D;fontFamily=Helvetica;fontSize=12;fillColor=#DEEBFF;strokeColor=#C1C7D0;" vertex="1" parent="1"><mxGeometry x="230" y="332" width="80" height="58" as="geometry"/></mxCell><mxCell id="t3" value="shard 3" style="rounded=1;arcSize=8;absoluteArcSize=1;html=1;whiteSpace=wrap;fontColor=#172B4D;fontFamily=Helvetica;fontSize=12;fillColor=#DEEBFF;strokeColor=#C1C7D0;" vertex="1" parent="1"><mxGeometry x="310" y="332" width="80" height="58" as="geometry"/></mxCell><mxCell id="t4" value="shard 4" style="rounded=1;arcSize=8;absoluteArcSize=1;html=1;whiteSpace=wrap;fontStyle=1;fontColor=#974F0C;fontFamily=Helvetica;fontSize=12;fillColor=#FFE9A8;strokeColor=#FF991F;strokeWidth=1.6;" vertex="1" parent="1"><mxGeometry x="390" y="332" width="80" height="58" as="geometry"/></mxCell><mxCell id="t5" value="shard 5" style="rounded=1;arcSize=8;absoluteArcSize=1;html=1;whiteSpace=wrap;fontStyle=1;fontColor=#974F0C;fontFamily=Helvetica;fontSize=12;fillColor=#FFE9A8;strokeColor=#FF991F;strokeWidth=1.6;" vertex="1" parent="1"><mxGeometry x="470" y="332" width="80" height="58" as="geometry"/></mxCell><mxCell id="t6" value="shard 6" style="rounded=1;arcSize=8;absoluteArcSize=1;html=1;whiteSpace=wrap;fontStyle=1;fontColor=#974F0C;fontFamily=Helvetica;fontSize=12;fillColor=#FFE9A8;strokeColor=#FF991F;strokeWidth=1.6;" vertex="1" parent="1"><mxGeometry x="550" y="332" width="80" height="58" as="geometry"/></mxCell><mxCell id="t7" value="shard 7" style="rounded=1;arcSize=8;absoluteArcSize=1;html=1;whiteSpace=wrap;fontStyle=1;fontColor=#974F0C;fontFamily=Helvetica;fontSize=12;fillColor=#FFE9A8;strokeColor=#FF991F;strokeWidth=1.6;" vertex="1" parent="1"><mxGeometry x="630" y="332" width="80" height="58" as="geometry"/></mxCell><mxCell id="t8" value="shard 8" style="rounded=1;arcSize=8;absoluteArcSize=1;html=1;whiteSpace=wrap;fontColor=#172B4D;fontFamily=Helvetica;fontSize=12;fillColor=#DEEBFF;strokeColor=#C1C7D0;" vertex="1" parent="1"><mxGeometry x="710" y="332" width="80" height="58" as="geometry"/></mxCell><mxCell id="t9" value="shard 9" style="rounded=1;arcSize=8;absoluteArcSize=1;html=1;whiteSpace=wrap;fontColor=#172B4D;fontFamily=Helvetica;fontSize=12;fillColor=#DEEBFF;strokeColor=#C1C7D0;" vertex="1" parent="1"><mxGeometry x="790" y="332" width="80" height="58" as="geometry"/></mxCell><mxCell id="t10" value="shard 10" style="rounded=1;arcSize=8;absoluteArcSize=1;html=1;whiteSpace=wrap;fontColor=#172B4D;fontFamily=Helvetica;fontSize=12;fillColor=#DEEBFF;strokeColor=#C1C7D0;" vertex="1" parent="1"><mxGeometry x="870" y="332" width="80" height="58" as="geometry"/></mxCell><mxCell id="t11" value="shard 11" style="rounded=1;arcSize=8;absoluteArcSize=1;html=1;whiteSpace=wrap;fontColor=#172B4D;fontFamily=Helvetica;fontSize=12;fillColor=#DEEBFF;strokeColor=#C1C7D0;" vertex="1" parent="1"><mxGeometry x="950" y="332" width="80" height="58" as="geometry"/></mxCell><mxCell id="p1" value="" style="endArrow=none;dashed=1;dashPattern=4 4;strokeColor=#FF991F;strokeWidth=1.4;html=1;exitX=0;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="s1" target="t4"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="p2" value="" style="endArrow=none;dashed=1;dashPattern=4 4;strokeColor=#FF991F;strokeWidth=1.4;html=1;exitX=1;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="s1" target="t7"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="del" value="Routing-less delete for D0&lt;br&gt;(source shard 1 — no routing key)" style="rounded=1;arcSize=8;absoluteArcSize=1;html=1;whiteSpace=wrap;fontColor=#42526E;fontFamily=Helvetica;fontSize=12;fillColor=#FFFFFF;strokeColor=#8993A4;" vertex="1" parent="1"><mxGeometry x="150" y="470" width="320" height="60" as="geometry"/></mxCell><mxCell id="blk" value="target shards&lt;br&gt;4 &#183; 5 &#183; 6 &#183; 7" style="rounded=1;arcSize=8;absoluteArcSize=1;html=1;whiteSpace=wrap;fontStyle=1;fontColor=#974F0C;fontFamily=Helvetica;fontSize=12;fillColor=#FFE9A8;strokeColor=#FF991F;strokeWidth=1.6;" vertex="1" parent="1"><mxGeometry x="560" y="471" width="200" height="58" as="geometry"/></mxCell><mxCell id="fan" value="fan out (bulk delete)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;endFill=1;dashed=1;dashPattern=1 4;strokeColor=#42526E;fontColor=#42526E;strokeWidth=1.6;fontFamily=Helvetica;fontSize=12;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="del" target="blk"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="safe" value="D0 is on exactly one of the four. Fan the delete&lt;br&gt;to all four: it removes D0 from the shard that&lt;br&gt;holds it, and is a harmless no-op on the rest." style="text;html=1;align=left;verticalAlign=top;fontColor=#42526E;fontFamily=Helvetica;fontSize=12;fontSize=12;" vertex="1" parent="1"><mxGeometry x="800" y="470" width="320" height="60" as="geometry"/></mxCell></root></mxGraphModel></diagram></mxfile>